  namespace: robot-shop
data:
  api-key: CAHNGEME
  project-id: CAHNGEME
type: Opaque

---
# Source: robot-shop/templates/web-service.yaml
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  namespace: robot-shop
  name: web
spec:
  to:
    kind: Service
    name: web
---
kind: Route
apiVersion: route.openshift.io/v1
metadata:
  namespace: robot-shop
  name: robotshop
spec:
  to:
    kind: Service
    name: web
    weight: 100
  port:
    targetPort: http
  tls:
    termination: edge
    insecureEdgeTerminationPolicy: Allow
  wildcardPolicy: None


