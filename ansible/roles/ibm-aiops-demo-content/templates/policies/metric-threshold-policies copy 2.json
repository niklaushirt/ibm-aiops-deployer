                                "$variable": "metric"
                            },
                            "summary": "Metric exceeds fixed threshold",
                            "severity": 5
                        },
                        "output": "anomalyEvent"
                    }, {
                        "actionId": "aiops/io/sendMessage",
                        "arguments": {
                            "channel": "events-input",
